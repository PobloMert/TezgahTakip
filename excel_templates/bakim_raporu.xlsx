from openpyxl import Workbook
from openpyxl.styles import Font, Alignment, Border, Side

wb = Workbook()
ws = wb.active

# Başlık
ws['A1'] = "TEZGAH BAKIM RAPORU"
ws['A1'].font = Font(bold=True, size=16)
ws.merge_cells('A1:E1')

# Sütun Başlıkları
headers = ['Tezgah No', 'Son Bakım Tarihi', 'Bakım Türü', 'Sorumlu', 'Durum']
for col, header in enumerate(headers, 1):
    cell = ws.cell(row=3, column=col, value=header)
    cell.font = Font(bold=True)

# Örnek Veriler
sample_data = [
    ['TZ-001', '01.05.2025', 'Periyodik', 'Ahmet Yılmaz', 'Tamamlandı'],
    ['TZ-002', '15.05.2025', 'Arıza', 'Mehmet Demir', 'Beklemede']
]

for row, data in enumerate(sample_data, 4):
    for col, value in enumerate(data, 1):
        ws.cell(row=row, column=col, value=value)

# Stil Ayarları
thin_border = Border(left=Side(style='thin'), right=Side(style='thin'), top=Side(style='thin'), bottom=Side(style='thin'))
for row in ws.iter_rows(min_row=3, max_row=5, max_col=5):
    for cell in row:
        cell.border = thin_border

wb.save('bakim_raporu.xlsx')
